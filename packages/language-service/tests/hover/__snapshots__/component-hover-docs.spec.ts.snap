// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`componentHoverDocs.ts > snapshots > JSDoc 1`] = `
"## Models

~~~ts
/**
 * This is the default model
 */
modelValue?: string | undefined

/**
 * This is a required model
 */
requiredModel: string

/**
 * This is a model with a default value
 */
modelWithDefault?: string | undefined = "default value"

/**
 * This is a deprecated model
 * 
 * @deprecated This model is deprecated and should not be used
 */
deprecatedModel?: string | undefined

/**
 * This is a model created without \`defineModel\`
 */
manualModel?: string | undefined

/**
 * This is a model created without \`defineModel\` and with a prop as an event
 */
manualModelWithPropEvent?: string | undefined
~~~


## Props

~~~ts
/**
 * This is a requird prop
 * 
 * @foo This is a custom tag
 */
requiredProp: string

/**
 * This is a prop with a default value
 */
withDefault?: boolean | undefined = false

/**
 * @description A very long description: Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
 * 
 * @anotherDescription Now with multiple lines!
 * Lorem ipsum
 * 
 * @name Some name
 */
justTags?: string | undefined

noDescription?: boolean | undefined

/**
 * Object type
 */
withObjectType?: { foo: string; bar: number; } | undefined

/**
 * With some markdown
 * 
 * # Who puts a title in a jsdoc comment?
 * 
 * > This is a blockquote
 * 
 * - This is a list item
 * - This is another list item
 */
withMarkdown?: string | undefined

/**
 * With code block
 * \`\`\`ts
 * const foo: string = 'bar'
 * \`\`\`
 */
withCodeBlock?: string | undefined

/**
 * This is a deprecated prop
 * 
 * @deprecated This prop is deprecated and should not be used
 */
deprecatedProp?: string | undefined

/**
 * Because the "l" is lower case this prop will is not being treated as
 * an event
 */
onlyAPropStartingWithOn?: string | undefined
~~~


## Events

~~~ts
@customEvent: () => any

@eventWithPayload: (payload: string, payload2: number) => any

@deprecatedEvent: () => any

/**
 * Because it starts with "onX" this prop is treated as an event
 */
@somePropEvent: ((value: string) => void) | undefined
~~~


## Slots

~~~ts
/**
 * This is a default slot
 */
#default

/**
 * This is a slot with props
 */
#slotWithProps: { foo: string; }

/**
 * This is a deprecated slot
 * 
 * @deprecated This slot is deprecated and should not be used
 */
#deprecatedSlot
~~~


## Exposed

~~~ts
/**
 * This is a method that can be called from the parent component
 */
exposedMethod: () => void

/**
 * This is a property that can be accessed from the parent component
 */
exposedProperty: string
~~~"
`;

exports[`componentHoverDocs.ts > snapshots > Markdown 1`] = `
"## Models

\`modelValue?: string | undefined\`

> This is the default model

\`requiredModel: string\`

> This is a required model

\`modelWithDefault?: string | undefined = "default value"\`

> This is a model with a default value

~~\`deprecatedModel?: string | undefined\`~~

> This is a deprecated model
> 
> ***@deprecated*** This model is deprecated and should not be used

\`manualModel?: string | undefined\`

> This is a model created without \`defineModel\`

\`manualModelWithPropEvent?: string | undefined\`

> This is a model created without \`defineModel\` and with a prop as an event

## Props

\`requiredProp: string\`

> This is a requird prop
> 
> ***@foo*** This is a custom tag

\`withDefault?: boolean | undefined = false\`

> This is a prop with a default value

\`justTags?: string | undefined\`

> 
> 
> ***@description*** A very long description: Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
> 
> ***@anotherDescription*** Now with multiple lines!
> Lorem ipsum
> 
> ***@name*** Some name

\`noDescription?: boolean | undefined\`

\`withObjectType?: { foo: string; bar: number; } | undefined\`

> Object type

\`withMarkdown?: string | undefined\`

> With some markdown
> 
> # Who puts a title in a jsdoc comment?
> 
> > This is a blockquote
> 
> - This is a list item
> - This is another list item

\`withCodeBlock?: string | undefined\`

> With code block
> \`\`\`ts
> const foo: string = 'bar'
> \`\`\`

~~\`deprecatedProp?: string | undefined\`~~

> This is a deprecated prop
> 
> ***@deprecated*** This prop is deprecated and should not be used

\`onlyAPropStartingWithOn?: string | undefined\`

> Because the "l" is lower case this prop will is not being treated as
> an event

## Events

\`@customEvent: () => any\`

\`@eventWithPayload: (payload: string, payload2: number) => any\`

\`@deprecatedEvent: () => any\`

\`@somePropEvent: ((value: string) => void) | undefined\`

> Because it starts with "onX" this prop is treated as an event

## Slots

\`#default\`

> This is a default slot

\`#slotWithProps\` - \`{ foo: string; }\`

> This is a slot with props

~~\`#deprecatedSlot\`~~

> This is a deprecated slot
> 
> ***@deprecated*** This slot is deprecated and should not be used

## Exposed

\`exposedMethod: () => void\`

> This is a method that can be called from the parent component

\`exposedProperty: string\`

> This is a property that can be accessed from the parent component"
`;

