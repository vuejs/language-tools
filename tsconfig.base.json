{
	"compilerOptions": {
		"target": "ES2021",
		"lib": ["ES2022"],
		"module": "Node16",
		"sourceMap": true,
		"composite": true,
		"skipLibCheck": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"forceConsistentCasingInFileNames": true,
		"noUncheckedIndexedAccess": true
	},
	"include": []
}
